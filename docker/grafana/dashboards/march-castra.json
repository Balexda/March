{
  "annotations": { "list": [] },
  "description": "RED metrics for the Castra interactive-sessions host (march-castra): request rate, errors, and latency by route and profile, plus service logs (Loki) and request traces (Tempo).",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "tags": ["march"],
      "targetBlank": false,
      "title": "March dashboards",
      "type": "dashboards"
    }
  ],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 11,
      "title": "Service health",
      "type": "row",
      "panels": []
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Heartbeat ticks in the last 5m. Castra emits one tick every 15s; >0 means it is alive and exporting metrics. Global (one shared host) — not filtered by profile.",
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "mappings": [], "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "id": 12,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Heartbeat (5m)",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "editorMode": "code", "expr": "sum(increase(march_castra_heartbeat_total[5m]))", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Process uptime of the Castra service.",
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "mappings": [], "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }, "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 1 },
      "id": 13,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Uptime",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "editorMode": "code", "expr": "max(march_castra_uptime_seconds)", "refId": "A" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "id": 1,
      "title": "Castra API (RED)",
      "type": "row",
      "panels": []
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 6, "x": 0, "y": 8 },
      "id": 2,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "title": "Request rate",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "sum(rate(march_castra_requests_total{profile=~\"$profile\", route=~\"$route\"}[$__rate_interval]))",
          "legendFormat": "req/s",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.01 }, { "color": "red", "value": 0.05 }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 6, "x": 6, "y": 8 },
      "id": 3,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "title": "Error ratio (5xx)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "sum(rate(march_castra_requests_total{profile=~\"$profile\", route=~\"$route\", status_class=\"5xx\"}[$__rate_interval])) / clamp_min(sum(rate(march_castra_requests_total{profile=~\"$profile\", route=~\"$route\"}[$__rate_interval])), 1e-9)",
          "legendFormat": "5xx ratio",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10, "stacking": { "mode": "normal", "group": "A" } } }, "overrides": [] },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "options": { "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "Request rate by status class",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "sum by (status_class) (rate(march_castra_requests_total{profile=~\"$profile\", route=~\"$route\"}[$__rate_interval]))",
          "legendFormat": "{{status_class}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "id": 5,
      "options": { "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "Request duration percentiles",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(march_castra_request_duration_seconds_bucket{profile=~\"$profile\", route=~\"$route\"}[$__rate_interval])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(march_castra_request_duration_seconds_bucket{profile=~\"$profile\", route=~\"$route\"}[$__rate_interval])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(march_castra_request_duration_seconds_bucket{profile=~\"$profile\", route=~\"$route\"}[$__rate_interval])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "id": 6,
      "options": { "showHeader": true },
      "title": "Requests by route & status class (in range)",
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "sum by (route, status_class) (increase(march_castra_requests_total{profile=~\"$profile\", route=~\"$route\"}[$__range]))",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 23 },
      "id": 7,
      "options": { "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "p95 request duration by route",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (le, route) (rate(march_castra_request_duration_seconds_bucket{profile=~\"$profile\", route=~\"$route\"}[$__rate_interval])))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "id": 8,
      "title": "Logs & traces",
      "type": "row",
      "panels": []
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Castra service logs (service.name=march-castra). The $profile filter is a no-op until Castra logs carry a profile field; /healthz liveness lines are dropped.",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 32 },
      "id": 9,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "expr": "{service_name=\"march-castra\"} != `/healthz` | profile=~\"$profile\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Castra service logs",
      "type": "logs"
    },
    {
      "datasource": { "type": "tempo", "uid": "tempo" },
      "description": "Recent Castra request traces (service.name=march-castra). Mutating ops (launch/send/set/remove) emit castra.<op> spans; with an x-march-slice-id header they nest under the dispatch trace. Click a trace id for the waterfall.",
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 32 },
      "id": 10,
      "options": {},
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "filters": [
            { "id": "service-name", "operator": "=", "scope": "resource", "tag": "service.name", "value": ["march-castra"], "valueType": "string" }
          ],
          "limit": 50,
          "queryType": "traceqlSearch",
          "refId": "A",
          "tableType": "traces"
        }
      ],
      "title": "Recent Castra traces",
      "type": "table"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["march", "castra", "observability"],
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(march_castra_requests_total, profile)",
        "includeAll": true,
        "label": "profile",
        "multi": true,
        "name": "profile",
        "options": [],
        "query": { "query": "label_values(march_castra_requests_total, profile)", "refId": "PrometheusVariableQueryEditor-VariableQuery" },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      },
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(march_castra_requests_total, route)",
        "includeAll": true,
        "label": "route",
        "multi": true,
        "name": "route",
        "options": [],
        "query": { "query": "label_values(march_castra_requests_total, route)", "refId": "PrometheusVariableQueryEditor-VariableQuery" },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
