      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (kind) (increase(march_brood_teardowns_total[5m]))",
          "legendFormat": "{{kind}}",
          "refId": "A"
        }
      ],
