  },
  "description": "March spawn observability: success rate, runtime, and per-dispatch traces. Backed by march_spawn_runs_total / march_spawn_duration_seconds (Prometheus) and dispatch traces (Tempo).",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "panels": [],
      "title": "Spawn success rate",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Share of spawn dispatches that exited 0, over the dashboard time range.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.8 },
              { "color": "green", "value": 0.95 }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "12.2.1",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "sum(increase(march_spawn_runs_total{backend=~\"$backend\", task_type=~\"$task_type\", profile=~\"$profile\", outcome=\"success\"}[$__range])) / clamp_min(sum(increase(march_spawn_runs_total{backend=~\"$backend\", task_type=~\"$task_type\", profile=~\"$profile\"}[$__range])), 1)",
          "legendFormat": "success rate",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Spawn success rate",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Total spawn dispatches in range, split by outcome.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "mappings": [],
          "unit": "short"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "success" }, "properties": [ { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } } ] },
          { "matcher": { "id": "byName", "options": "failure" }, "properties": [ { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } } ] }
        ]
      },
      "gridPos": { "h": 7, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "pluginVersion": "12.2.1",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "sum by (outcome) (increase(march_spawn_runs_total{backend=~\"$backend\", task_type=~\"$task_type\", profile=~\"$profile\"}[$__range]))",
          "legendFormat": "{{outcome}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Spawns in range (by outcome)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Spawn dispatch rate, split by outcome.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "spawns/sec",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 15,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "normal" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "unit": "short"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "success" }, "properties": [ { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } } ] },
          { "matcher": { "id": "byName", "options": "failure" }, "properties": [ { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } } ] }
        ]
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 1 },
      "id": 3,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "12.2.1",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "sum by (outcome) (rate(march_spawn_runs_total{backend=~\"$backend\", task_type=~\"$task_type\", profile=~\"$profile\"}[$__rate_interval]))",
          "legendFormat": "{{outcome}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Spawn rate by outcome",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Spawn counts in range, broken down by task type and outcome.",
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "inspect": false }, "mappings": [], "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 4,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true
      },
      "pluginVersion": "12.2.1",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "sum by (task_type, outcome) (increase(march_spawn_runs_total{backend=~\"$backend\", task_type=~\"$task_type\", profile=~\"$profile\"}[$__range]))",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Spawn counts by task type & outcome",
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true }, "renameByName": { "Value": "count", "task_type": "task type" } } }
      ],
      "type": "table"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Spawn wall-clock duration percentiles (from the march_spawn_duration_seconds histogram).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 5,
      "options": {
        "legend": { "calcs": ["max", "mean"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "12.2.1",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(march_spawn_duration_seconds_bucket{backend=~\"$backend\", task_type=~\"$task_type\", profile=~\"$profile\", outcome=~\"$outcome\"}[$__rate_interval])))",
          "legendFormat": "p50",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(march_spawn_duration_seconds_bucket{backend=~\"$backend\", task_type=~\"$task_type\", profile=~\"$profile\", outcome=~\"$outcome\"}[$__rate_interval])))",
          "legendFormat": "p95",
          "range": true,
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(march_spawn_duration_seconds_bucket{backend=~\"$backend\", task_type=~\"$task_type\", profile=~\"$profile\", outcome=~\"$outcome\"}[$__rate_interval])))",
          "legendFormat": "p99",
          "range": true,
          "refId": "C"
        }
      ],
      "title": "Spawn duration percentiles",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "p95 spawn duration split by task type — which kinds of work run long.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "id": 6,
      "options": {
        "legend": { "calcs": ["max", "mean"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "12.2.1",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (le, task_type) (rate(march_spawn_duration_seconds_bucket{backend=~\"$backend\", task_type=~\"$task_type\", profile=~\"$profile\", outcome=~\"$outcome\"}[$__rate_interval])))",
          "legendFormat": "{{task_type}} p95",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "p95 spawn duration by task type",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "id": 101,
      "panels": [],
      "title": "Per-dispatch traces",
      "type": "row"
    },
    {
      "datasource": { "type": "tempo", "uid": "tempo" },
      "description": "Recent dispatch traces. One trace per dispatched unit of work (trace id = hash(slice id)); spans nest legate.dispatch -> hatchery.spawn -> spawn.start/end/steward.apply + spawn.exec. Click a trace id to open the waterfall.",
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 25 },
      "id": 7,
      "options": {},
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "filters": [
            { "id": "service-name", "operator": "=", "scope": "resource", "tag": "service.name", "value": ["march", "march-legate"], "valueType": "string" }
          ],
          "limit": 50,
          "queryType": "traceqlSearch",
          "refId": "A",
          "tableType": "traces"
        }
      ],
      "title": "Recent dispatch traces",
      "type": "table"
    }
  ],
