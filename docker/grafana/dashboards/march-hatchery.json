    {
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "description": "Hatchery service logs (shipped from the JSONL log file via OTLP). If no lines appear, check the service_name label in Explore \u2014 otel-lgtm derives it from the service.name resource attribute. The $profile / $task_type filters are no-ops until issue #171 adds those structured fields to Hatchery logs (with the default 'All' they match every line); they activate once a specific value is selected.",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 25
      },
      "id": 9,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "editorMode": "code",
          "expr": "{service_name=\"march-hatchery\"} != `/healthz` | profile=~\"$profile\" | task_type=~\"$task_type\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Hatchery service logs",
      "type": "logs"
    },
    {
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "description": "Recent hatchery spawn traces (service.name=march-hatchery). Click a trace id to open the waterfall: hatchery.spawn -> spawn.start/end/steward.apply + spawn.exec.",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
