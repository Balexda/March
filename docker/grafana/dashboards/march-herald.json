    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Herald service logs (pino → Loki), service.name=march-herald.",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 26 },
      "id": 10,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
