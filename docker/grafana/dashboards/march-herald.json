    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 35 },
      "id": 104,
      "panels": [],
      "title": "Steward self-report (#371)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Steward self-reports recorded by Herald, by classification. `unclassified` is the cheap hook heuristic's miss that falls through to the (expensive) legate-agent; a rising unclassified share means the heuristics need updating.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 36 },
      "id": 12,
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (classification) (rate(march_herald_steward_reports_total[$__rate_interval]))",
          "legendFormat": "{{classification}}",
          "refId": "A"
        }
      ],
      "title": "Steward reports by classification",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Share of steward reports the cheap hook heuristic could classify (1 − unclassified/total) over the last 1h. A sustained drop means more reports are spilling to the expensive legate-agent — heuristics likely need updating. Shows 'No data' when no reports landed in the window.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 70 }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 36 },
      "id": 13,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 * sum(increase(march_herald_steward_reports_total{classification!=\"unclassified\"}[1h])) / sum(increase(march_herald_steward_reports_total[1h]))",
          "refId": "A"
        }
      ],
      "title": "Heuristic classification rate (1h)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Total steward self-reports recorded in the last 1h (all classifications) — report volume.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 36 },
      "id": 14,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
