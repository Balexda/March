# Build-context excludes for the repo-root build (docker/hatchery.Dockerfile).
# The spawn-codex image builds from the docker/ subdir and is unaffected.
.git
node_modules
dist
*.log
# ...but keep the march.* skill self-test fixtures (sample spawn-output.log
# files). `npm run build` regenerates the castra skill variant from these
# sources during the image build, so they must be in the build context.
!src/templates/skills/**/fixtures/**/*.log
.smithy
docs
